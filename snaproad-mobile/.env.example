# SnapRoad Mobile App - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# IMPORTANT: EXPO ENVIRONMENT VARIABLE RULES
# ===========================================
# 
# In Expo, environment variables MUST be prefixed with EXPO_PUBLIC_ to be 
# accessible in your JavaScript/TypeScript code.
#
# ❌ WRONG: API_URL=http://...         (will NOT work!)
# ✅ RIGHT: EXPO_PUBLIC_API_URL=http://...
#
# Access in code:
#   const apiUrl = process.env.EXPO_PUBLIC_API_URL;
#
# After changing .env, restart metro bundler:
#   npx expo start --clear
#
# ===========================================

# ===========================================
# API CONFIGURATION (Required)
# ===========================================
# Development - use your local backend IP (not localhost on physical device!)
# Find your IP: ifconfig (Mac) or ipconfig (Windows)
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:8001/api

# If testing on same machine with simulator:
# EXPO_PUBLIC_API_URL=http://localhost:8001/api

# Production (update with your actual domain)
# EXPO_PUBLIC_API_URL=https://api.snaproad.com/api

# ===========================================
# EXPO PUSH NOTIFICATIONS (Required for notifications)
# ===========================================
# Get from: https://expo.dev → Projects → Your Project → Project ID
EXPO_PUBLIC_PUSH_NOTIFICATION_PROJECT_ID=your-expo-project-id

# ===========================================
# APPLE MAPKIT JS (Optional - for directions/search)
# Basic map display works without these!
# Only needed if implementing turn-by-turn navigation
# ===========================================
# EXPO_PUBLIC_APPLE_TEAM_ID=your-apple-team-id
# EXPO_PUBLIC_APPLE_KEY_ID=your-mapkit-key-id

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
EXPO_PUBLIC_ENABLE_PREMIUM=true
EXPO_PUBLIC_ENABLE_CHALLENGES=true

