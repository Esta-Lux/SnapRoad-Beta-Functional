# SnapRoad Mobile - Environment Configuration Template
# Copy this file to .env and fill in your values
# IMPORTANT: Restart metro bundler after changes: npx expo start --clear

# API URL - Your backend server URL (do NOT include /api suffix - screens append it)
# Examples:
#   Local development: http://localhost:8001
#   Production: https://your-backend.example.com
EXPO_PUBLIC_API_URL=http://localhost:8001

# Push Notifications (get from expo.dev)
EXPO_PUBLIC_PUSH_NOTIFICATION_PROJECT_ID=

# Stripe Payment Integration
# Get your publishable key at: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXX

# Feature Flags
EXPO_PUBLIC_ENABLE_PREMIUM=true
EXPO_PUBLIC_ENABLE_CHALLENGES=true
