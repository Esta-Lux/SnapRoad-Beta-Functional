# SnapRoad Mobile App - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API CONFIGURATION (Required)
# ===========================================
# Development
API_URL=http://localhost:8001/api

# Production (update with your actual domain)
# API_URL=https://api.snaproad.com/api

# ===========================================
# EXPO PUSH NOTIFICATIONS (Required)
# ===========================================
EXPO_PUBLIC_PUSH_NOTIFICATION_PROJECT_ID=your-expo-project-id

# ===========================================
# APPLE MAPKIT JS (Optional - for directions/search)
# Basic map display works without these!
# Only needed if implementing turn-by-turn navigation
# ===========================================
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-mapkit-key-id
# APPLE_PRIVATE_KEY=contents-of-p8-file

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
ENABLE_PREMIUM=true
ENABLE_CHALLENGES=true
