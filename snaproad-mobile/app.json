{
  "expo": {
    "name": "SnapRoad",
    "slug": "snaproad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snaproad.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SnapRoad needs your location to show nearby offers and track your driving.",
        "NSLocationAlwaysUsageDescription": "SnapRoad needs your location to provide navigation and safety features."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.snaproad.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SnapRoad needs your location for navigation and nearby offers."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "367755bb-8925-4849-9958-1ad5bd0d0567"
      }
    }
  }
}
