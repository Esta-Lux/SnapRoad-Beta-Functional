# SnapRoad Frontend - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API CONFIGURATION (Required)
# ===========================================
# Development
VITE_API_URL=/api
REACT_APP_BACKEND_URL=http://localhost:8001

# Production (update with your actual domain)
# REACT_APP_BACKEND_URL=https://api.snaproad.com

# ===========================================
# MAPS (Required for production)
# ===========================================
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ===========================================
# STRIPE (Required for payments)
# ===========================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# VITE_MIXPANEL_TOKEN=your-mixpanel-token
# VITE_GA_ID=G-XXXXXXXXXX

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
VITE_ENABLE_PREMIUM=true
VITE_ENABLE_CHALLENGES=true
VITE_ENABLE_AI_IMAGES=true
