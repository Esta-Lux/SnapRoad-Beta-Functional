# Dependencies
node_modules/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
playwright-report/
test-results/
playwright/.cache/

# Environment files (keep .env.example)
.env
.env.e2e
app/frontend/.env.e2e
app/mobile/.env
app/mobile/.env.*
!app/mobile/.env.example
.env.local
.env.development
.env.production
!.env.example

# Private keys (MapKit .p8, local key dirs)
keys/
.mapkit/
*.p8

# Build outputs
dist/
build/
.vite/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Testing
coverage/
.coverage
htmlcov/

# Misc
*.bak
*.tmp
.vercel

# Supabase CLI local cache (may contain project refs / connection strings)
supabase/.temp/
app/mobile/supabase/.temp/

# Sentry mcp config
.cursor/mcp.json

# Prevent root-level Expo/EAS config that confuses monorepo builds.
# The real configs live in app/mobile/.
/eas.json
/app.json
/app.config.js
/app.config.ts
