# SnapRoad Backend - Environment Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# AI CONFIGURATION (Required for Orion Coach & Photo Analysis)
# ===========================================
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Specify models (defaults shown)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# ===========================================
# DATABASE (Choose one)
# ===========================================

# Option A: Supabase (Recommended for production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Option B: MongoDB (Alternative)
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=snaproad

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# PAYMENTS (Stripe)
# ===========================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Optional: For webhook signature verification
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# MAPS (Optional - for production directions)
# ===========================================
# Apple MapKit JS
# APPLE_MAPKIT_TEAM_ID=your-team-id
# APPLE_MAPKIT_KEY_ID=your-key-id
# APPLE_MAPKIT_PRIVATE_KEY=your-p8-private-key

# OR Google Maps
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# ===========================================
# NOTIFICATIONS (Optional)
# ===========================================
# SendGrid for emails
# SENDGRID_API_KEY=SG.your-sendgrid-key

# Twilio for SMS
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890

# Firebase for push notifications
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email
