# SnapRoad Backend API - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/snaproad
# OR MongoDB
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/snaproad
# DB_NAME=snaproad

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# Auth0 (if using Auth0)
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_API_AUDIENCE=https://api.snaproad.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret

# Firebase Auth (if using Firebase)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key

# ===========================================
# MAPS & GEOCODING (Required)
# ===========================================
# Mapbox (recommended)
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# Google Maps (alternative)
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# ===========================================
# PAYMENTS - STRIPE (Required)
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ===========================================
# AI IMAGE GENERATION (Optional)
# ===========================================
# OpenAI DALL-E
OPENAI_API_KEY=sk-your-openai-key

# Stability AI (alternative)
# STABILITY_API_KEY=sk-your-stability-key

# Replicate (alternative)
# REPLICATE_API_TOKEN=r8_your-replicate-token

# ===========================================
# EMAIL SERVICE (Optional)
# ===========================================
SENDGRID_API_KEY=SG.your-sendgrid-key
FROM_EMAIL=noreply@snaproad.com

# ===========================================
# PUSH NOTIFICATIONS (Optional)
# ===========================================
FIREBASE_SERVER_KEY=your-firebase-server-key
# OR
# FCM_API_KEY=your-fcm-api-key

# ===========================================
# GAS PRICES API (Optional)
# ===========================================
# GAS_PRICE_API_KEY=your-gas-api-key

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=8001
ENVIRONMENT=development
# ENVIRONMENT=production

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# LOGGING & MONITORING (Optional)
# ===========================================
# SENTRY_DSN=https://your-sentry-dsn
# LOG_LEVEL=INFO
