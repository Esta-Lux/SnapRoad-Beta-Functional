{
  "name": "sandbox-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --outdir=dist --platform=node --target=node20 --format=esm --packages=external --sourcemap",
    "typecheck": "tsc --noEmit",
    "start": "node --import @specific-dev/framework/telemetry dist/index.js",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "npm run db:generate && npm run db:migrate"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.2.17",
    "@fastify/aws-lambda": "6.1.1",
    "@fastify/multipart": "9.3.0",
    "@fastify/swagger": "9.6.1",
    "@neondatabase/serverless": "1.0.2",
    "@fastify/websocket": "11.2.0",
    "@specific-dev/framework": "1.34.1",
    "better-auth": "1.6.2",
    "commander": "12.1.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "drizzle-kit": "0.31.5",
    "esbuild": "0.27.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "better-auth": "$better-auth",
    "drizzle-orm": "$drizzle-orm",
    "fastify": "$fastify",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "@opentelemetry/auto-instrumentations-node": "0.75.0",
    "@opentelemetry/exporter-prometheus": "0.217.0",
    "@opentelemetry/sdk-node": "0.217.0",
    "protobufjs": "8.2.0",
    "@protobufjs/utf8": "1.1.1"
  }
}
