{
  "name": "mobile",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "tunnel:api": "cloudflared tunnel --no-autoupdate --url http://localhost:8001",
    "start:dev:tunnel": "expo start --dev-client --tunnel --clear",
    "start:dev:lan": "node ./scripts/start-dev-client-lan.mjs",
    "eas:build:dev:ios": "node ../../scripts/eas-build-mobile.mjs build --profile development --platform ios",
    "eas:build:dev:android": "node ../../scripts/eas-build-mobile.mjs build --profile development --platform android",
    "eas:build:dev:ios-sim": "node ../../scripts/eas-build-mobile.mjs build --profile development-simulator --platform ios",
    "eas:build:prod:ios": "node ../../scripts/eas-build-mobile.mjs build --profile production --platform ios",
    "eas:build:prod:android": "node ../../scripts/eas-build-mobile.mjs build --profile production --platform android --clear-cache",
    "eas:update:production": "node ../../scripts/eas-build-mobile.mjs update --channel production --environment production",
    "eas:submit:ios": "node scripts/submit-ios-testflight.cjs",
    "eas:submit:ios:interactive": "eas submit --platform ios --latest",
    "android:sha1": "bash scripts/print-android-sha1.sh",
    "postinstall": "node scripts/restore-expo-vector-fonts.cjs",
    "test": "tsx --test \"src/**/*.smoke.test.ts\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/ionicons": "^12.5.0",
    "@react-native-voice/voice": "^3.2.4",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/stack": "^7.8.7",
    "@rnmapbox/maps": "^10.3.0",
    "@sentry/react-native": "~7.2.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.100.0",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-battery": "~10.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-screen-capture": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@react-native-voice/voice": {
      "@expo/config-plugins": "54.0.4"
    }
  },
  "private": true
}
