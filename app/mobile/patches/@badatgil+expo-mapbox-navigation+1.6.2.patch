+    private func navProgressPayload(progressState: RouteProgressState) -> [String: Any] {
+        let rp = progressState.routeProgress
+        let leg = rp.currentLegProgress
+        let stepProg = leg.currentStepProgress
+        let visual = stepProg.currentVisualInstruction
+        let step = leg.currentStep
+        var out: [String: Any] = [
+            "distanceRemaining": rp.distanceRemaining,
+            "distanceTraveled": rp.distanceTraveled,
+            "durationRemaining": rp.durationRemaining,
+            "fractionTraveled": rp.fractionTraveled,
+            "legIndex": rp.legIndex,
+            "stepIndex": leg.stepIndex,
+            "maneuverType": String(describing: step.maneuverType),
+        ]
+        if let md = step.maneuverDirection {
+            out["maneuverDirection"] = String(describing: md)
+        }
+        if let p = visual?.primaryInstruction.text {
+            out["primaryInstruction"] = p
+        }
+        if let s = visual?.secondaryInstruction?.text {
+            out["secondaryInstruction"] = s
+        }
+        if let d = stepProg.userDistanceToUpcomingIntersection {
+            out["distanceToNextManeuverMeters"] = d
+        }
+        if let sl = leg.currentSpeedLimit {
+            out["speedLimitMps"] = sl.converted(to: .metersPerSecond).value
+        }
+        if let up = rp.upcomingStep {
+            out["thenInstruction"] = up.instructions
+        }
+        out["currentStepInstruction"] = step.instructions
+        return out
+    }
