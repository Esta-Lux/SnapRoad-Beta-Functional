+    private func makeSnapRoadTrafficCameraIcon() -> UIImage? {
+        let size = CGSize(width: 40, height: 40)
+        UIGraphicsBeginImageContextWithOptions(size, false, 0)
+        defer { UIGraphicsEndImageContext() }
+        guard let ctx = UIGraphicsGetCurrentContext() else { return nil }
+        ctx.setFillColor(UIColor(red: 0.15, green: 0.45, blue: 0.95, alpha: 1).cgColor)
+        ctx.fillEllipse(in: CGRect(origin: .zero, size: size))
+        ctx.setStrokeColor(UIColor.white.cgColor)
+        ctx.setLineWidth(2)
+        ctx.strokeEllipse(in: CGRect(x: 1.5, y: 1.5, width: size.width - 3, height: size.height - 3))
+        let cfg = UIImage.SymbolConfiguration(pointSize: 18, weight: .semibold)
+        if let sym = UIImage(systemName: "video.fill", withConfiguration: cfg) {
+            let tinted = sym.withTintColor(.white, renderingMode: .alwaysOriginal)
+            tinted.draw(in: CGRect(x: 9, y: 9, width: 22, height: 22))
+        }
+        return UIGraphicsGetImageFromCurrentImageContext()
+    }
