+    private func updateTrafficCameraLayer() {
+        guard let mapView = navigationViewController?.navigationMapView?.mapView,
+              let mapboxMap = mapView.mapboxMap else { return }
+
+        if mapboxMap.layerExists(withId: snaproadTrafficCamLayerId) {
+            try? mapboxMap.removeLayer(withId: snaproadTrafficCamLayerId)
+        }
+        if mapboxMap.sourceExists(withId: snaproadTrafficCamSourceId) {
+            try? mapboxMap.removeSource(withId: snaproadTrafficCamSourceId)
+        }
+
+        guard let raw = trafficCamerasJson,
+              let data = raw.data(using: .utf8),
+              let arr = try? JSONSerialization.jsonObject(with: data) as? [[String: Any]],
+              !arr.isEmpty
+        else { return }
+
+        var features: [[String: Any]] = []
+        for item in arr {
+            let lat = (item["lat"] as? Double) ?? (item["latitude"] as? Double)
+            let lng = (item["lng"] as? Double) ?? (item["longitude"] as? Double)
+            guard let lat, let lng else { continue }
+            let id = String(describing: item["id"] ?? "")
+            let name = (item["name"] as? String) ?? "Traffic camera"
+            features.append([
+                "type": "Feature",
+                "geometry": [
+                    "type": "Point",
+                    "coordinates": [lng, lat],
+                ],
+                "properties": [
+                    "id": id,
+                    "name": name,
+                ],
+            ])
+        }
+        guard !features.isEmpty else { return }
+        let fc: [String: Any] = ["type": "FeatureCollection", "features": features]
+        guard let fcData = try? JSONSerialization.data(withJSONObject: fc),
+              let fcString = String(data: fcData, encoding: .utf8) else { return }
+
+        if !mapboxMap.imageExists(withId: snaproadTrafficCamImageId) {
+            if let img = makeSnapRoadTrafficCameraIcon() {
+                try? mapboxMap.addImage(img, id: snaproadTrafficCamImageId, stretchX: [], stretchY: [])
+            }
+        }
+
+        var source = GeoJSONSource(id: snaproadTrafficCamSourceId)
+        source.data = .string(fcString)
+        do {
+            try mapboxMap.addSource(source)
+            var layer = SymbolLayer(id: snaproadTrafficCamLayerId, source: snaproadTrafficCamSourceId)
+            layer.iconImage = .constant(.name(snaproadTrafficCamImageId))
+            layer.iconAllowOverlap = .constant(true)
+            layer.iconIgnorePlacement = .constant(true)
+            layer.iconSize = .constant(0.9)
+            let anchorIds = [
+                "com.mapbox.navigation.route_line.main",
+                "com.mapbox.navigation.layerGroup.main.main",
+                "com.mapbox.navigation.route_line.traffic",
+                "road-label",
+            ]
+            if let above = anchorIds.first(where: { mapboxMap.layerExists(withId: $0) }) {
+                try mapboxMap.addLayer(layer, layerPosition: .above(above))
+            } else {
+                try mapboxMap.addLayer(layer)
+            }
+            installTrafficCameraTapIfNeeded(on: mapView)
+        } catch {}
+    }
