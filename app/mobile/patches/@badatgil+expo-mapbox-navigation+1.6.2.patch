+    private func installTrafficCameraTapIfNeeded(on mapView: MapView) {
+        if trafficCameraTapRecognizer != nil { return }
+        let tap = UITapGestureRecognizer(target: self, action: #selector(handleTrafficCameraMapTap(_:)))
+        tap.cancelsTouchesInView = false
+        tap.delegate = self
+        mapView.addGestureRecognizer(tap)
+        trafficCameraTapRecognizer = tap
+    }
+
+    @objc private func handleTrafficCameraMapTap(_ gr: UITapGestureRecognizer) {
+        guard let mapView = navigationViewController?.navigationMapView?.mapView,
+              let mapboxMap = mapView.mapboxMap else { return }
+        let point = gr.location(in: mapView)
+        mapboxMap.queryRenderedFeatures(
+            with: point,
+            options: RenderedQueryOptions(layerIds: [snaproadTrafficCamLayerId], filter: nil)
+        ) { [weak self] result in
+            switch result {
+            case .success(let features):
+                guard let first = features.first else { return }
+                var id = ""
+                var name = ""
+                if let props = first.queriedFeature.feature.properties {
+                    if let raw = props["id"], let v = raw { id = snaproadStringFromJSONValue(v) }
+                    if let raw = props["name"], let v = raw { name = snaproadStringFromJSONValue(v) }
+                }
+                if name.isEmpty { name = "Traffic camera" }
+                self?.onTrafficCameraTap?(["id": id, "name": name])
+            case .failure:
+                break
+            }
+        }
+    }
