+    private fun navProgressPayload(routeProgress: RouteProgress): Map<String, Any> {
+        val m =
+                mutableMapOf<String, Any>(
+                        "distanceRemaining" to routeProgress.distanceRemaining,
+                        "distanceTraveled" to routeProgress.distanceTraveled,
+                        "durationRemaining" to routeProgress.durationRemaining,
+                        "fractionTraveled" to routeProgress.fractionTraveled
+                )
+        try {
+            m["legIndex"] = routeProgress.currentLegIndex
+            val leg = routeProgress.currentLegProgress
+            m["stepIndex"] = leg.currentStepIndex
+            val stepProg = leg.currentStepProgress
+            m["distanceToNextManeuverMeters"] = stepProg.distanceRemaining
+            val maneuvers = maneuverApi.getManeuvers(routeProgress)
+            val primary = maneuvers.firstOrNull()?.primary
+            primary?.text?.let { m["primaryInstruction"] = it }
+            primary?.maneuverType?.let { m["maneuverType"] = it }
+        } catch (_: Throwable) {
+            // optional enrichment — keep core progress fields
+        }
+        return m
+    }
