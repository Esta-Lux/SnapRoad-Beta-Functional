# Allow admin/partner on /driver when combined with VITE_APP_ENV=preview or staging (or local `vite` dev).
# VITE_ALLOW_STAFF_IN_DRIVER_APP=true
# VITE_APP_ENV=preview
#
# Host role (app.snaproad.app production):
#   VITE_SITE_PROFILE=partner  → / opens partner portal; /driver shows “use mobile app” (hostname app.snaproad.app also implies this)
#   omit or VITE_SITE_PROFILE=full → local / preview: driver web at /driver works as before
#
# --- Vercel (production): only names starting with VITE_ are embedded in the browser bundle. ---
# Required (same Supabase project as Railway SUPABASE_URL):
#   VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
#   VITE_SUPABASE_ANON_KEY=sb_publishable_...
# Required (API host for fetch() — no trailing slash):
#   VITE_API_URL=https://api.snaproad.app
#   (or VITE_BACKEND_URL — same value)
# Strongly recommended:
#   VITE_MAPBOX_TOKEN=pk.eyJ...
#   VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...
#   (Do not set OHGO on Vercel — cameras go through GET /api/map/cameras; set OHGO_API_KEY on Railway only.)
# Station-level gas near the user: backend GET /api/fuel/prices — set TOMTOM_API_KEY on Railway only (no VITE_ copy).
# Sentry in the SPA uses VITE_SENTRY_DSN — not SENTRY_DSN (that name is ignored by Vite).
# Do NOT set MAPKIT_* / GOOGLE_* / SUPABASE_* without VITE_ on Vercel — they will not be visible to the app.

# Backend / API (required for Orion and API calls)
# Local dev: leave empty to use Vite proxy, or set http://127.0.0.1:8001
# Production (Vercel): point both at the Railway API (no trailing slash)
# VITE_API_URL=https://api.snaproad.app
# VITE_BACKEND_URL=https://api.snaproad.app
#
# Partner referral links & QR codes — set to the live partner host (required for correct /join?ref= links in prod):
# VITE_PARTNER_PORTAL_URL=https://app.snaproad.app
VITE_API_URL=
VITE_BACKEND_URL=

# Supabase (friend location, realtime) - keep set for friend sharing
# MUST be the same Supabase project as Railway SUPABASE_URL or OAuth + token exchange will fail with 401.
# Compare `project_ref` from https://api.snaproad.app/api/config/supabase to your VITE_SUPABASE_URL host.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Maps
VITE_MAPBOX_TOKEN=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAP_ID=

# Orion uses backend NVIDIA_API_KEY or OPENAI_API_KEY only — never put API keys in the frontend.

# Payments
VITE_STRIPE_PUBLISHABLE_KEY=

# OHGO: not used in the browser; backend holds OHGO_API_KEY.
