# SnapRoad Backend - Environment Configuration
# Copy to .env and fill in your values. Do not commit .env.
#
# This file (or shell env) is what uvicorn loads when you run the API locally — including
# npm run dev:mobile. Expo EAS secrets are for the mobile *build* only; they are not injected
# into this FastAPI process.
#
# --- Minimal Supabase for Railway (same project as Vercel/EAS, different KEY TYPE) ---
# Required: SUPABASE_URL + SUPABASE_SECRET_KEY (service role from Dashboard → Settings → API).
# Do NOT put the anon / publishable key in SUPABASE_SECRET_KEY — GET /health will stay "degraded"
# and auth will fail. Vercel uses anon; Railway uses service_role only.
# Optional: SUPABASE_PUBLISHABLE_KEY (backend rarely needs it; not required for get_supabase()).
# Railway misconfig: SUPABASE_ANON_KEY alone does nothing — the server never reads it. You still need SUPABASE_SECRET_KEY.

# Database (Supabase)
SUPABASE_URL=
# Server key: Dashboard → Settings → API → "service_role" / secret (sb_secret_… or legacy JWT). NOT the anon key.
SUPABASE_SECRET_KEY=
# Alias (same value as SUPABASE_SECRET_KEY); config.py reads either name.
# SUPABASE_SERVICE_ROLE_KEY=

# GET /health probes public.profiles — run sql/supabase_migration.sql + 017_profiles_boosts_badges.sql if missing.
SUPABASE_DB_PASSWORD=

# Supabase Dashboard → Authentication → URL Configuration (manual):
# Partner portal (browser): https://app.snaproad.app — set PARTNER_PORTAL_ORIGIN to match (Stripe return URLs, invite links).
# Site URL / Supabase redirect URLs: https://app.snaproad.app/**

# Driver "Submit Concern" (POST /api/concerns/submit) needs table public.concerns — run sql/005_concerns_app_config.sql in Supabase if you see HTTP 503.

# Driver map incidents (POST /api/incidents/report) — public.road_reports + SUPABASE_SECRET_KEY (service role).
# 503 "Incident service unavailable" = Supabase insert/query failed (logs include full traceback). Set on Railway:
# EXPOSE_INCIDENT_BACKEND_ERRORS=1
# …to append str(error) to the 503 JSON detail while debugging; turn off after.
# app_config.incident_submissions_enabled: if explicitly false, returns "Incident reporting is temporarily disabled." instead.
# app_config.incident_submissions_enabled: if explicitly false, returns "Incident reporting is temporarily disabled." instead.
# Missing that key (or sb_get_app_config fails → {}): submissions stay enabled (default True). See services/runtime_config.py.

# Optional: GET /api/incidents/osm-nearby merges OpenStreetMap (Overpass) construction/traffic-calming hints.
# Enabled by default; set OSM_INCIDENTS_ENABLED=0 to disable (local dev, outages, or etiquette).
OSM_INCIDENTS_ENABLED=1

# Auth
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# Runtime
ENVIRONMENT=development

# --- Production (Railway) ---
# Railway sets RAILWAY_ENVIRONMENT — the API skips HTTPSRedirect (TLS is at the edge).
# If the container exits immediately, check Deploy logs: often missing CORS_ORIGINS, JWT_SECRET (32+ chars),
# SUPABASE_*, or Stripe keys when ENVIRONMENT=production.

# Browser origins allowed to call the API (comma-separated). Trailing slashes are normalized.
# In production or on Railway (RAILWAY_* env), SnapRoad web/API origins are merged in (app/www/apex/api.snaproad.app
# and http://app.snaproad.app) — even if ENVIRONMENT is not set to production. Still set CORS_ORIGINS explicitly.
# CORS_ORIGINS=https://app.snaproad.app,https://api.snaproad.app,http://app.snaproad.app
#
# Stripe checkout success/cancel URLs use this allowlist (comma-separated origins, no trailing slash on list items).
# Must match the exact origin the app sends as origin_url and where /payment/success lives.
# PARTNER_PORTAL_ORIGIN=https://app.snaproad.app
# CHECKOUT_ALLOWED_ORIGINS=https://app.snaproad.app

# Local / staging CORS (comma-separated, no spaces)
# CORS_ORIGINS=http://localhost:3000,https://app.snaproad.app

# Orion / photo AI — OpenAI is tried first when OPENAI_API_KEY is set; NVIDIA is used if OpenAI
# fails (or as the only provider if no OpenAI key). Keys stay server-side only.
# https://build.nvidia.com — NVIDIA keys often start with nvapi-.
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# OpenAI (primary when set — Orion, vision, trips summaries)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
# Optional: image model for partner promo generator (/api/images/generate)
# OPENAI_IMAGE_MODEL=dall-e-3

# Stripe (checkout / billing portal for web, Android, and B2B / partner plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Apple In-App Purchase (iOS consumer Premium / Family) — App Store Connect → Users and Access → Integrations → In-App Purchase (.p8)
# Run sql/051_profiles_apple_iap.sql on Supabase for apple_* columns.
#
# ⚠ SERVER ONLY — set these on Railway (API), NOT on Expo/EAS. The app-store-server JWT key must never ship in mobile builds.
# (scripts/sync-eas-env.mjs skips APPLE_* uploaded from merged backend.env.)
#
# APPLE_IAP_KEY_ID=<10-char Key ID from ASC>
# APPLE_IAP_ISSUER_ID=<Issuer UUID from ASC → Keys>
# APPLE_IAP_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_IAP_BUNDLE_ID=com.snaproad.app
# APPLE_APP_APPLE_ID=<numeric App ID from ASC → App → App Information — required for production JWS>
# APPLE_IAP_PREMIUM_PRODUCT_ID=com.snaproad.app.premium.monthly.plan
# Optional legacy Apple IAP family SKU (leave unset when only Premium is sold on ASC).
# APPLE_IAP_FAMILY_PRODUCT_ID=
# Mobile: EXPO_PUBLIC_APPLE_IAP_PREMIUM must match this Product ID (see app/mobile/.env.example).
# Optional: public HTTPS origin printed in diagnostics (defaults to https://api.snaproad.app).
# SNAPROAD_PUBLIC_API_BASE=https://api.snaproad.app
# App Store Server Notifications V2 (IAP) — configure under App → App Information (not team Webhooks).

# ASC *Connect Webhooks* (TestFlight feedback, build status, etc.) use a Payload URL + mandatory Secret YOU invent.
# That secret is not from Apple — generate locally, e.g. `openssl rand -base64 32`, paste the same string into ASC,
# store on API as env (verify requests with Apple's `x-apple-signature` HMAC-SHA256). Do not reuse IAP .p8 keys.
# Do not POST those webhooks to /api/payments/apple/notifications (wrong payload).

# IAP Server Notifications V2 POST URL (same SNAPROAD_PUBLIC_API_BASE): /api/payments/apple/notifications
# After deploy: GET /YOUR_API_HOST/api/payments/apple/status — configured should be true for iOS IAP sync.

# ---
MAPKIT_KEY_ID=
MAPKIT_TEAM_ID=
MAPKIT_PRIVATE_KEY_PATH=
# Or paste raw key (no path):
# MAPKIT_PRIVATE_KEY=

# Cameras / Traffic API - used for auth when calling external cameras or traffic APIs
CAMERAS_API_KEY=your-cameras-api-key
# Optional: cameras API base URL (request sends lat, lng, radius, key as query params)
# CAMERAS_API_URL=https://api.example.com/cameras

# Ohio DOT traffic cameras (OHGO) — populates GET /api/map/traffic for Expo when lat/lng are sent.
# Dashboard: https://publicapi.ohgo.com/accounts/dashboard — same key as web VITE_OHGO_API_KEY.
# OHGO_API_KEY=
# Optional; default https://publicapi.ohgo.com — must match where /api/v1/cameras lives.
# OHGO_API_URL=https://publicapi.ohgo.com

# CollectAPI — statewide US gasoline averages for GET /api/map/gas-prices (mobile map layer).
# Backend tries https://api.collectapi.com/gasPrice/allUsaPrice first, then falls back to the
# documented https://api.collectapi.com/gasPrice/stateUsaPrice?state=WA shape (`gasoline` → regular).
# Token: collectapi.com → Accounts → Profile → Token (paste the raw token only, no "Bearer " prefix required).
# Official docs: `Authorization: YOUR_TOKEN` (we try that first, then apikey / Bearer variants).
# Railway: set COLLECTAPI_KEY on the *API* service (same service as uvicorn), redeploy/restart so the process
# picks up `os.environ`. GET /api/map/gas-prices returns `collectapi_configured: false` when the key is missing.
# Also accepted: COLLECT_API_KEY, COLLECTAPI_TOKEN (see config._pick_collectapi_key).
# COLLECTAPI_KEY=

# TomTom — nearby station prices for GET /api/fuel/prices (Search + Fuel Prices APIs).
# Dashboard: https://developer.tomtom.com/ — create a secret API key with Search + Fuel Prices enabled.
# The map tile URL (…/map/1/tile/…) uses the same key family but is unrelated to fuel pricing.
# Set only on the backend (Railway / local app/backend/.env). Never add TOMTOM_* to Vite / Expo public env.
# If the key lacks Fuel Prices entitlement, responses may have no station prices — the API falls back to GasBuddy / mock.
# TOMTOM_API_KEY=
# Optional: product / app UUID shown next to the key in TomTom dashboard (for your records; not required for REST).
# TOMTOM_CLIENT_ID=
# Same key is used by routes/places.py and routes/directions.py.
GOOGLE_PLACES_API_KEY=
# Optional: use a separate key for Maps/Directions (otherwise GOOGLE_PLACES_API_KEY is used)
# GOOGLE_MAPS_API_KEY=

# Commute cron (POST /api/commute-routes/internal/dispatch and .../dispatch-traffic):
# Prefer HMAC (works everywhere in production):
#   X-Internal-Timestamp: Unix seconds
#   X-Internal-Signature: hex(HMAC-SHA256(secret, "{ts}\n" + raw_body))
#   secret = COMMUTE_INTERNAL_HMAC_SECRET or COMMUTE_DISPATCH_SECRET
# Run: python scripts/commute_dispatch_hmac.py --path /api/commute-routes/internal/dispatch
# Plain header X-Commute-Dispatch-Secret == COMMUTE_DISPATCH_SECRET is accepted on Railway
# (RAILWAY_ENVIRONMENT / RAILWAY_PROJECT_ID set) or when COMMUTE_INTERNAL_ALLOW_LEGACY_SECRET=1.
# COMMUTE_INTERNAL_HMAC_SECRET=
# COMMUTE_DISPATCH_SECRET=
# COMMUTE_INTERNAL_ALLOW_LEGACY_SECRET=false

# Optional: run dispatch loops inside this API process (no external cron / Railway Cron).
# Use a single backend replica or expect duplicate pushes if multiple workers run the ticker.
# COMMUTE_EMBEDDED_DISPATCH=1
# COMMUTE_EMBEDDED_SCAN_INTERVAL_SEC=180
# COMMUTE_EMBEDDED_TRAFFIC_INTERVAL_SEC=600

# Dev-only mock bearer tokens (Authorization: Bearer mock_token_<user_id>). Requires ENABLE_MOCK_BEARER_AUTH=true
# or ALLOW_MOCK_AUTH=true in non-production. Forbidden when ENVIRONMENT=production.
# ENABLE_MOCK_BEARER_AUTH=false
