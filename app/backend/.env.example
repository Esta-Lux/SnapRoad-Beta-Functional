# SnapRoad Backend - Environment Configuration
# Copy to .env and fill in your values. Do not commit .env.
#
# This file (or shell env) is what uvicorn loads when you run the API locally — including
# npm run dev:mobile. Expo EAS secrets are for the mobile *build* only; they are not injected
# into this FastAPI process.

# Database (Supabase)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_DB_PASSWORD=

# Driver "Submit Concern" (POST /api/concerns/submit) needs table public.concerns — run sql/005_concerns_app_config.sql in Supabase if you see HTTP 503.

# Auth
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# Runtime
ENVIRONMENT=development
# Required in production (comma-separated, no spaces)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# OpenAI (Orion Coach, Photo Analysis)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MapKit (Apple Maps)
MAPKIT_KEY_ID=
MAPKIT_TEAM_ID=
MAPKIT_PRIVATE_KEY_PATH=
# Or paste raw key (no path):
# MAPKIT_PRIVATE_KEY=

# Cameras / Traffic API - used for auth when calling external cameras or traffic APIs
CAMERAS_API_KEY=your-cameras-api-key
# Optional: cameras API base URL (request sends lat, lng, radius, key as query params)
# CAMERAS_API_URL=https://api.example.com/cameras

# Ohio DOT traffic cameras (OHGO) — populates GET /api/map/traffic for Expo when lat/lng are sent.
# Dashboard: https://publicapi.ohgo.com/accounts/dashboard — same key as web VITE_OHGO_API_KEY.
# OHGO_API_KEY=
# Optional; default https://publicapi.ohgo.com — must match where /api/v1/cameras lives.
# OHGO_API_URL=https://publicapi.ohgo.com

# Google Maps / Places / Directions - used for Places API proxy and Directions API proxy (GET /api/directions)
# Same key is used by routes/places.py and routes/directions.py.
GOOGLE_PLACES_API_KEY=
# Optional: use a separate key for Maps/Directions (otherwise GOOGLE_PLACES_API_KEY is used)
# GOOGLE_MAPS_API_KEY=

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com
