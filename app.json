{
  "expo": {
    "name": "Beta Pulse",
    "slug": "beta-pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/mobile/assets/brand-logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./app/mobile/assets/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/mobile/assets/brand-logo.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./app/mobile/assets/brand-logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "betapulse",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://x5jsht3sek55zgv53ztubrdp75t26uvc.app.specular.dev"
    }
  }
}